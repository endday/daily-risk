{
  "name": "daily-risk-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute daily-risk --file=migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute daily-risk --local --file=migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "date-fns": "^4.4.0"
  }
}
